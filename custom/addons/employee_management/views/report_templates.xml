<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <template id="report_customs">
        <t t-call="web.external_layout">

            <main>
                <div class="page">

                    <h2>Customs Exemption Report</h2>

                    <table class="table table-sm table-bordered">
                        <thead>
                            <tr>
                                <th>Product</th>
                                <th>HS Code</th>
                                <th>Country</th>

                                <th>Cost (€)</th>
                                <th>Cost (AED)</th>

                                <th>Freight (€)</th>
                                <th>Freight (AED)</th>

                                <th>Exemption (AED)</th>

                                <th>Total (€)</th>
                                <th>Total (AED)</th>
                            </tr>
                        </thead>

                        <tbody>
                            <t t-foreach="lines" t-as="l">
                                <tr>
                                    <td><t t-esc="l['product']"/></td>
                                    <td><t t-esc="l['hs_code']"/></td>
                                    <td><t t-esc="l['country']"/></td>

                                  <td><t t-esc="l['cost_price_eur']"/></td>
<td><t t-esc="l['cost_price_aed']"/></td>
<td><t t-esc="l['freight_eur']"/></td>
<td><t t-esc="l['freight_aed']"/></td>
<td><t t-esc="l['exemption_aed']"/></td>
<td><t t-esc="l['total_eur']"/></td>
<td><t t-esc="l['total_aed']"/></td>
                                </tr>
                            </t>
                        </tbody>

                    </table>

                </div>
            </main>

        </t>
    </template>

</odoo>