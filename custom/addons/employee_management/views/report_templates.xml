<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <template id="report_customs">
        <t t-call="web.external_layout">

            <main>
                <div class="page">

                    <h2>Customs Exemption Report</h2>

                    <table class="table table-sm table-bordered">
                        <thead>
                            <tr>
                                <th>Landed Cost</th>
                                <th>Product</th>
                                <th>HS Code</th>
                                <th>Country</th>
                                <th>Cost Price</th>
                                <th>Freight/Duty</th>
                                <th>Exemption</th>
                                <th>Final Landed</th>
                                <th>Total Cost</th>
                            </tr>
                        </thead>

                        <tbody>
                            <t t-foreach="lines" t-as="l">
                                <tr>
                                    <td><t t-esc="l['cost_name']"/></td>
                                    <td><t t-esc="l['product']"/></td>
                                    <td><t t-esc="l['hs_code']"/></td>
                                    <td><t t-esc="l['country']"/></td>

                                    <td><t t-esc="l['cost_price']"/></td>
                                    <td><t t-esc="l['original_cost']"/></td>
                                    <td><t t-esc="l['exemption']"/></td>
                                    <td><t t-esc="l['final_cost']"/></td>
                                    <td><t t-esc="l['total_cost']"/></td>
                                </tr>
                            </t>
                        </tbody>

                    </table>

                </div>
            </main>

        </t>
    </template>

</odoo>