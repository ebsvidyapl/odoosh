<odoo>
    <template id="report_customs">
        <t t-call="web.external_layout">

            <main>
                <div class="page">

                    <h2>Customs Report</h2>

                    <table class="table table-bordered">
                        <thead>
                            <tr>
                                <th>Landed Cost</th>
                                <th>Product</th>
                                <th>HS Code</th>
                                <th>Country</th>
                                <th>Purchase Cost</th>
                                <th>Duty Fee</th>
                                <th>Exemption</th>
                            </tr>
                        </thead>

                        <tbody>
                            <t t-foreach="lines" t-as="l">
                                <tr>
                                    <td><t t-esc="l['cost_name']"/></td>
                                    <td><t t-esc="l['product']"/></td>
                                    <td><t t-esc="l['hs_code']"/></td>
                                    <td><t t-esc="l['country']"/></td>
                                    <td><t t-esc="l['purchase_cost']"/></td>
                                    <td><t t-esc="l['duty_fee']"/></td>
                                    <td><t t-esc="l['exemption']"/></td>
                                </tr>
                            </t>
                        </tbody>

                    </table>

                </div>
            </main>

        </t>
    </template>
</odoo>