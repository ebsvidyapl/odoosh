<odoo>
    <template id="report_customs">
        <t t-call="web.external_layout">
            <main>
                <div class="page">

                    <h2>Customs Exemption Report</h2>

                    <table class="table table-sm table-bordered">
                        <thead>
                            <tr>
                                <th>Landed Cost</th>
                                <th>Product</th>
                                <th>HS Code</th>
                                <th>Country</th>
                                <th>Original Duty</th>
                                <th>Applied Duty</th>
                                <th>Exemption</th>
                                <th>Status</th>
                            </tr>
                        </thead>

                        <tbody>
                            <t t-foreach="lines" t-as="l">
                                <tr>
                                    <td><t t-esc="l['cost_name']"/></td>
                                    <td><t t-esc="l['product']"/></td>
                                    <td><t t-esc="l['hs_code']"/></td>
                                    <td><t t-esc="l['country']"/></td>

                                    <td><t t-esc="l['original_duty']"/></td>
                                    <td><t t-esc="l['applied_duty']"/></td>
                                    <td><t t-esc="l['exemption']"/></td>

                                    <td>
                                        <t t-if="l['type'] == 'full'">
                                            Duty Free
                                        </t>
                                        <t t-elif="l['type'] == 'partial'">
                                            Partial
                                        </t>
                                        <t t-else="">
                                            Normal
                                        </t>
                                    </td>
                                </tr>
                            </t>
                        </tbody>

                    </table>

                </div>
            </main>
        </t>
    </template>
</odoo>