<odoo>

<!-- LIST VIEW -->
<record id="employee_list" model="ir.ui.view">
    <field name="name">employee.list</field>
    <field name="model">employee.management</field>
    <field name="arch" type="xml">
        <list>
            <field name="name"/>
            <field name="age"/>
            <field name="email" optional="show"/>
            <field name="department_id" optional="show"/>
            <field name="salary" optional="hide"/>
            <field name="annual_salary"/>
        </list>
    </field>
</record>

<!-- FORM VIEW -->
<record id="employee_form" model="ir.ui.view">
    <field name="name">employee.form</field>
    <field name="model">employee.management</field>
    <field name="arch" type="xml">
        <form>
         <header>
                <button name="%(employee_report_action)d"
                        string="Print Report"
                        type="action"
                        class="btn-primary"/>
            </header>
            <sheet>
                <group>
                    <field name="employee_code" readonly="1"/>
                    <field name="name"/>
                    <field name="age"/>
                    <field name="email"/>
                    <field name="department_id" optional="show"/>
                    <field name="salary"/>
                    <field name="annual_salary"/>
                </group>
                  <notebook>

                    <!-- BASIC DETAILS TAB -->
                    <page string="Basic Details">
                        <group>
                            <field name="name"/>
                            <field name="age"/>
                            <field name="email"/>
                           <field name="department_id" optional="show"/>
                            <field name="salary"/>
                            <field name="annual_salary"/>
                        </group>
                    </page>

                    <!-- PERSONAL DETAILS TAB -->
                    <page string="Personal Details">
                        <group>
                            <field name="phone"/>
                            <field name="gender" optional="show"/>
                            <field name="date_of_birth"/>
                            <field name="address"/>
                        </group>
                    </page>

                </notebook>

            </sheet>
        </form>
    </field>
</record>
<!-- SEARCH VIEW -->
<record id="employee_search_view" model="ir.ui.view">
    <field name="name">employee.search</field>
    <field name="model">employee.management</field>
    <field name="arch" type="xml">
        <search>

            <!-- Search Fields -->
            <field name="name"/>
            <field name="age"/>
            <field name="date_of_birth"/>
            <field name="department_id"/>

            <separator/>

            <!-- Filters -->
            <filter string="Age Above 30"
                    name="age_above_30"
                    domain="[('age','&gt;',30)]"/>

            <filter string="Age Below 20"
                    name="age_below_20"
                    domain="[('age','&lt;',20)]"/>

            <separator/>

            <!-- Group By -->
            <filter string="Group by Age"
                    name="group_by_age"
                    context="{'group_by': 'age'}"/>

            <filter string="Group by Department"
                    name="group_by_department"
                    context="{'group_by': 'department_id'}"/>

        </search>
    </field>
</record>

<!-- KANBAN VIEW -->
<record id="employee_kanban_view" model="ir.ui.view">
    <field name="name">employee.kanban</field>
    <field name="model">employee.management</field>
    <field name="arch" type="xml">
        <kanban>
            <field name="name"/>
            <field name="department_id"/>
            <field name="email"/>
            <field name="salary"/>
            <field name="annual_salary"/>

            <templates>
                <t t-name="card">
                    <div class="o_kanban_record p-3">
                        <strong><field name="name"/></strong>
                        <div>Department: <field name="department_id"/></div>
                        <div>Email: <field name="email"/></div>
                        <div>Salary: <field name="salary"/></div>
                        <div>Annual Salary:<field name="annual_salary"/></div>
                    </div>
                </t>
            </templates>
        </kanban>
    </field>
</record>

<!-- ACTION (must come AFTER views) -->
<record id="employee_action" model="ir.actions.act_window">
    <field name="name">Employees</field>
    <field name="res_model">employee.management</field>

    <!-- Correct view order -->
    <field name="view_mode">kanban,list,form</field>

    <!-- Explicitly connect views -->
    <field name="views" eval="[
        (ref('employee_kanban_view'), 'kanban'),
        (ref('employee_list'), 'list'),
        (ref('employee_form'), 'form')
    ]"/>

    <field name="search_view_id" ref="employee_search_view"/>
</record>

<!-- MENU -->
<menuitem id="employee_root"
          name="Employee Management"
          sequence="10"/>

<menuitem id="employee_menu"
          name="Employees"
          parent="employee_root"
          action="employee_action"
          sequence="1"/>
</odoo>