<odoo>
    <record id="view_customs_rule_form" model="ir.ui.view">
        <field name="name">customs.rule.form</field>
        <field name="model">customs.exemption.rule</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="hs_code"/>
                        <field name="country_id"/>
                        <field name="exemption_type"/>
                        <field name="exemption_percentage"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_customs_rule_tree" model="ir.ui.view">
        <field name="name">customs.rule.tree</field>
        <field name="model">customs.exemption.rule</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="hs_code"/>
                <field name="country_id"/>
                <field name="exemption_type"/>
            </tree>
        </field>
    </record>
</odoo>