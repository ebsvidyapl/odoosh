<odoo>
    <record id="view_partner_form_approval" model="ir.ui.view">
        <field name="name">res.partner.form.approval</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">

            <xpath expr="//header" position="inside">
                <button name="action_submit_for_approval"
                        type="object"
                        string="Submit Approval"
                        class="btn-primary"
                        groups="employee_management.group_sales_team"
                        invisible="approval_state != 'draft'"/>

                <button name="action_approve_partner"
                        type="object"
                        string="Approve"
                        class="btn-success"
                        groups="employee_management.group_management"
                        invisible="approval_state != 'pending'"/>
            </xpath>

            <xpath expr="//sheet/notebook" position="before">
                <group>
                    <field name="approval_state" readonly="1"/>
                    <field name="approved_by" readonly="1"/>
                </group>
            </xpath>

        </field>
    </record>
</odoo>