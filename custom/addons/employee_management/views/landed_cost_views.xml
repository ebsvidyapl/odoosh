<odoo>

    <record id="view_landed_cost_form_customs" model="ir.ui.view">
        <field name="name">stock.landed.cost.form.customs</field>
        <field name="model">stock.landed.cost</field>
        <field name="inherit_id" ref="stock_landed_costs.view_stock_landed_cost_form"/>

        <field name="arch" type="xml">

            <!-- ✅ SAFER TARGET -->
            <xpath expr="//field[@name='valuation_adjustment_lines']/tree" position="inside">

                <field name="purchase_cost"/>
                <field name="duty_fee"/>
                <field name="exemption_applied"/>

            </xpath>

            <!-- BUTTON -->
            <xpath expr="//header" position="inside">
                <button name="%(action_customs_report)d"
                        string="Print Customs Report"
                        type="action"
                        class="btn-primary"/>
            </xpath>

        </field>
    </record>

</odoo>