<odoo>
    <data>

        <!-- ROOT MENU -->
        <menuitem id="menu_customs_root"
                  name="Customs"
                  parent="stock.menu_stock_config_settings"
                  sequence="45"
                  groups="stock.group_stock_manager"/>

        <!-- ACTION -->
        <record id="action_customs_rule" model="ir.actions.act_window">
            <field name="name">Customs Rules</field>
            <field name="res_model">customs.exemption.rule</field>
            <field name="view_mode">list,form</field>
        </record>

        <!-- CHILD MENU -->
        <menuitem id="menu_customs_rules"
                  name="Exemption Rules"
                  parent="menu_customs_root"
                  action="action_customs_rule"
                  groups="stock.group_stock_manager"
                  sequence="10"/>

    </data>
</odoo>