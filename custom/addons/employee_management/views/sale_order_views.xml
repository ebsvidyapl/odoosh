<odoo>

<record id="view_sale_order_form_inherit_file_upload" model="ir.ui.view">
    <field name="name">sale.order.form.file.upload</field>
    <field name="model">sale.order</field>
    <field name="inherit_id" ref="sale.view_order_form"/>
    <field name="arch" type="xml">

        <!-- Add field inside Other Info tab -->
        <xpath expr="//sheet/notebook" position="inside">

            <page string="Attachments">
                <group>
                    <field name="quotation_file" filename="quotation_filename"/>
                    <field name="quotation_filename" invisible="1"/>
                </group>
            </page>

        </xpath>

    </field>
</record>

</odoo>