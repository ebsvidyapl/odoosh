<odoo>
    <data>

        <!-- Create module category -->
        <record id="module_category_employee_mgmt" model="ir.module.category">
            <field name="name">Employee Management</field>
        </record>

        <!-- Groups -->
        <record id="group_management" model="res.groups">
            <field name="name">Management</field>
            <field name="category_id" ref="module_category_employee_mgmt"/>
        </record>

        <record id="group_sales_officer" model="res.groups">
            <field name="name">Sales Officer</field>
            <field name="category_id" ref="module_category_employee_mgmt"/>
        </record>

        <record id="group_logistics" model="res.groups">
            <field name="name">Logistics</field>
            <field name="category_id" ref="module_category_employee_mgmt"/>
        </record>

        <record id="group_accountant" model="res.groups">
            <field name="name">Accountant</field>
            <field name="category_id" ref="module_category_employee_mgmt"/>
        </record>

        <!-- CRM menu restriction -->
        <menuitem 
            id="crm.crm_menu_root"
            groups="sales_team.group_sale_salesman,sales_team.group_sale_manager"
        />

    </data>
</odoo>