<odoo>

    <!-- Prevent Sales Team from accessing Settings -->
    <record id="sales_team_no_settings" model="ir.rule">
        <field name="name">Sales No Settings Access</field>
        <field name="model_id" ref="base.model_ir_config_parameter"/>
        <field name="groups" eval="[(4, ref('employee_management.group_sales_team'))]"/>
        <field name="domain_force">[(0, '=', 1)]</field>
    </record>

    <!-- Hide Vendors -->
    <record id="rule_hide_vendors_accountant" model="ir.rule">
        <field name="name">Hide Vendors</field>
        <field name="model_id" ref="base.model_res_partner"/>
        <field name="groups" eval="[(4, ref('employee_management.group_accountant_restricted'))]"/>
        <field name="domain_force">[('supplier_rank', '=', 0)]</field>
    </record>

    <!-- Hide Products -->
    <record id="rule_hide_products_accountant" model="ir.rule">
        <field name="name">Hide Products</field>
        <field name="model_id" ref="product.model_product_template"/>
        <field name="groups" eval="[(4, ref('employee_management.group_accountant_restricted'))]"/>
        <field name="domain_force">[(0,'=',1)]</field>
    </record>

   </odoo>