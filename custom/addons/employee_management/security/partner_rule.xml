<odoo>
    <data>

        <record id="partner_rule_non_management" model="ir.rule">
            <field name="name">Hide Unapproved Partners</field>
            <field name="model_id" ref="base.model_res_partner"/>
            <field name="groups" eval="[(4, ref('employee_management.group_sales_officer')),
                                        (4, ref('employee_management.group_logistics')),
                                        (4, ref('employee_management.group_accountant'))]"/>
            <field name="domain_force">[('approval_state','=','approved')]</field>
        </record>

    </data>
</odoo>