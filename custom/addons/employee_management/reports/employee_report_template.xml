<odoo>

<template id="employee_report_template">

<t t-call="web.html_container">

<t t-foreach="docs" t-as="doc">

<t t-call="web.external_layout">

<div class="page">

<h2 style="text-align:center;">Employee Report</h2>

<table class="table table-bordered">

<tr>
<th>Name</th>
<td><span t-field="doc.name"/></td>
</tr>

<tr>
<th>Email</th>
<td><span t-field="doc.email"/></td>
</tr>

<tr>
<th>Department</th>
<td><span t-field="doc.department_id"/></td>
</tr>

<tr>
<th>Salary</th>
<td><span t-field="doc.salary"/></td>
</tr>

</table>

</div>

</t>

</t>

</t>

</template>

</odoo>