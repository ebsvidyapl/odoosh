<odoo>

<record id="view_sale_order_form_inherit_file_upload" model="ir.ui.view">
    <field name="name">sale.order.form.file.upload</field>
    <field name="model">sale.order</field>
    <field name="inherit_id" ref="sale.view_order_form"/>
    <field name="arch" type="xml">

        <!-- Add field inside Other Info tab -->
        <xpath expr="//sheet/notebook" position="inside">

            <page string="Attachments">
                <group>
                    <field name="quotation_file" filename="quotation_filename"/>
                    <field name="quotation_filename" invisible="1"/>
                </group>
            </page>

        </xpath>

    </field>
</record>
 <record id="view_sale_order_form_inherit_purchase_button" model="ir.ui.view">
        <field name="name">sale.order.form.purchase.button</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">

            <xpath expr="//header" position="inside">
                <button name="action_create_purchase_order"
                        type="object"
                        string="Create Purchase Order"
                        class="btn-primary"/>
            </xpath>

        </field>
    </record>
</odoo>