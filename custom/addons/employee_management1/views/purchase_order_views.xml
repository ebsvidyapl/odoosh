<odoo>
    <record id="view_purchase_order_form_inherit_lead_time" model="ir.ui.view">
        <field name="name">purchase.order.form.lead.time</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">

            <!-- Place Lead Time right after Order Date -->
            <xpath expr="//field[@name='date_order']" position="after">
                <field name="lead_time" string="Lead Time (Days)"/>
            </xpath>

        </field>
    </record>
</odoo>