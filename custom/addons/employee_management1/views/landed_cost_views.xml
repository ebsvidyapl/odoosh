<odoo>

    <record id="view_landed_cost_form_customs" model="ir.ui.view">
        <field name="name">stock.landed.cost.form.customs</field>
        <field name="model">stock.landed.cost</field>
        <field name="inherit_id" ref="stock_landed_costs.view_stock_landed_cost_form"/>
        <field name="arch" type="xml">

            <xpath expr="//sheet/group" position="inside">
                <group string="Customs Info">
                    <div class="o_form_label">
                        Customs exemption will be auto-applied based on HS Code and Country
                    </div>
                </group>
            </xpath>

        </field>
    </record>

</odoo>